# scraper/.env.example
# ─────────────────────
# Copy this file to scraper/.env and fill in your values.
# .env is gitignored — never commit it.
#
#   cp scraper/.env.example scraper/.env

# ── AWS ───────────────────────────────────────────────────────────────────────
# Named profile created with:  aws configure --profile careers-surf
# Uses the long-term access key from careersSurfAdmin_accessKeys.csv
# so the scraper works unattended without an SSO session.
AWS_PROFILE=careers-surf
AWS_REGION=eu-north-1

# S3 bucket that stores scraped job data
S3_BUCKET=careers-surf-data

# ── Optional: proxy ───────────────────────────────────────────────────────────
# Uncomment and fill in to route Puppeteer through a residential proxy.
# Supported formats: http://user:pass@host:port  |  socks5://user:pass@host:port
# SCRAPER_PROXY_URL=
